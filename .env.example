# ── ElevenLabs ───────────────────────────────────────────────────────────────
# The Conversational AI agent ID Tata calls should be routed to by default.
# Can be overridden per-connection via ?agent_id=<id> query param.
ELEVENLABS_AGENT_ID=your_agent_id_here

# Override the ElevenLabs WebSocket base URL (optional).
# Useful for EU / US / India residency endpoints.
# ELEVENLABS_WS_URL=wss://api.eu.residency.elevenlabs.io/v1/convai/conversation

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
