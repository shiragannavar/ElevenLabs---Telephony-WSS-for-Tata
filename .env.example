# ElevenLabs
# Optional default agent (used if direction-specific IDs are not set and no agent_id query param is supplied)
ELEVENLABS_AGENT_ID=your_agent_id_here
# Direction-aware agent IDs (chosen automatically based on Tata `start.direction`)
ELEVENLABS_AGENT_ID_INBOUND=
ELEVENLABS_AGENT_ID_OUTBOUND=
# Default residency is IN (api.in.residency.elevenlabs.io). Override here for other regions.
# ELEVENLABS_WS_URL=wss://api.elevenlabs.io/v1/convai/conversation
# ELEVENLABS_WS_URL=wss://api.eu.residency.elevenlabs.io/v1/convai/conversation
# ELEVENLABS_WS_URL=wss://api.us.residency.elevenlabs.io/v1/convai/conversation

# Tata Click-to-Call
TATA_CTC_API_KEY=your_tata_api_key
TATA_CALLER_ID=918069651024
TATA_CTC_URL=https://api-smartflo.tatateleservices.com/v1/click_to_call_support
WSS_PUBLIC_HOST=3.109.216.10.sslip.io

# Server
HOST=0.0.0.0
PORT=8000
